worker_processes  {{ awx_nginx_worker_processes }};
worker_cpu_affinity  {{ awx_nginx_worker_cpu_affinity }};

pid        /tmp/nginx.pid;

events {
    worker_connections {% if awx_nginx_worker_connections > 1024 %}{{ awx_nginx_worker_connections }}{% else %}1024{% endif %};
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    server_tokens off;
    client_max_body_size 5M;

    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log /dev/stdout main;

    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    sendfile        on;
    #tcp_nopush     on;
    #gzip  on;

    upstream uwsgi {
        server 127.0.0.1:{{ awx_uwsgi_port }};
        }

    upstream daphne {
        server 127.0.0.1:{{ awx_daphne_port }};
    }

    server {
        listen {{ awx_nginx_http_port }} default_server{% if awx_nginx_listen_queue_size > 511 %} backlog={{ awx_nginx_listen_queue_size }}{% endif %};
        listen [::]:{{ awx_nginx_http_port }} default_server{% if awx_nginx_listen_queue_size > 511 %} backlog={{ awx_nginx_listen_queue_size }}{% endif %};
        server_name _;

        # Redirect all HTTP links to the matching HTTPS page
        return 301 https://$host:{{ awx_nginx_https_port }}$request_uri;
    }

    server {
        listen {{ awx_nginx_https_port }} ssl{% if awx_nginx_listen_queue_size > 511 %} backlog={{ awx_nginx_listen_queue_size }}{% endif %};
        listen [::]:{{ awx_nginx_https_port }} ssl{% if awx_nginx_listen_queue_size > 511 %} backlog={{ awx_nginx_listen_queue_size }}{% endif %};

        ssl_certificate /etc/tower/tower.crt;
        ssl_certificate_key /etc/tower/tower.key;
        ssl_session_cache shared:SSL:50m;
        ssl_session_timeout 1d;
        ssl_session_tickets off;

        ssl_protocols {{ awx_nginx_https_protocols | join(' ') }};
        ssl_ciphers PROFILE=SYSTEM;
        ssl_prefer_server_ciphers on;

        # If you have a domain name, this is where to add it
        server_name _;
        keepalive_timeout 65;

        # HSTS (ngx_http_headers_module is required) (15768000 seconds = 6 months)
        add_header Strict-Transport-Security max-age=15768000;
        # Protect against click-jacking https://www.owasp.org/index.php/Testing_for_Clickjacking_(OTG-CLIENT-009)
        add_header X-Frame-Options "DENY";
        # Protect against MIME content sniffing https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/X-Content-Type-Options
        add_header X-Content-Type-Options nosniff;
        add_header Content-Security-Policy "default-src 'self'; connect-src 'self' ws: wss:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; report-uri /csp-violation/";

        location /nginx_status {
          stub_status on;
          access_log off;
          allow 127.0.0.1;
          deny all;
        }

        location /static/ {
            alias /var/lib/awx/public/static/;
        }

        location /locales {
            alias /var/lib/awx/public/static/awx/locales;
        }

        location /favicon.ico {
            alias /var/lib/awx/public/static/awx/awx-icon.svg;
        }

        location = /awx-icon.svg {
            alias /var/lib/awx/public/static/awx/awx-icon.svg;
        }

        location = /assets/awx-logo.svg {
            alias /var/lib/awx/public/static/awx/awx-logo.svg;
        }

        location ~ ^(/websocket/|/api/websocket/) {
            # Pass request to the upstream alias
            proxy_pass http://daphne;
            # Require http version 1.1 to allow for upgrade requests
            proxy_http_version 1.1;
            # We want proxy_buffering off for proxying to websockets.
            proxy_buffering off;
            # http://en.wikipedia.org/wiki/X-Forwarded-For
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto {{ awx_broadcast_websocket_protocol }};
            # pass the Host: header from the client for the sake of redirects
            proxy_set_header Host $http_host;
            # We've set the Host header, so we don't need Nginx to muddle
            # about with redirects
            proxy_redirect off;
            # Depending on the request value, set the Upgrade and
            # connection headers
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        location /api {
            uwsgi_read_timeout 120s;
            uwsgi_pass uwsgi;
            include /etc/nginx/uwsgi_params;
            proxy_set_header X-Forwarded-Port {{ awx_nginx_https_port }};
            uwsgi_param HTTP_X_FORWARDED_PORT {{ awx_nginx_https_port }};
        }

        location /sso {
            uwsgi_read_timeout 120s;
            uwsgi_pass uwsgi;
            include /etc/nginx/uwsgi_params;
            proxy_set_header X-Forwarded-Port {{ awx_nginx_https_port }};
            uwsgi_param HTTP_X_FORWARDED_PORT {{ awx_nginx_https_port }};
        }

        location /login {
            uwsgi_read_timeout 120s;
            uwsgi_pass uwsgi;
            include /etc/nginx/uwsgi_params;
            proxy_set_header X-Forwarded-Port {{ awx_nginx_https_port }};
            uwsgi_param HTTP_X_FORWARDED_PORT {{ awx_nginx_https_port }};
        }

        location /csp-violation {
            uwsgi_pass uwsgi;
            include /etc/nginx/uwsgi_params;
        }

        location /migrations_notran {
            uwsgi_pass uwsgi;
            include /etc/nginx/uwsgi_params;
        }

        location / {
            root /var/lib/awx/public/static/awx;
            try_files $uri /static/awx/index_awx.html;

            add_header Strict-Transport-Security max-age=15768000;
            add_header Content-Security-Policy "default-src 'self'; connect-src 'self' ws: wss:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; report-uri /csp-violation/";
            add_header X-Frame-Options "DENY";
            add_header X-Content-Type-Options nosniff;
            add_header Cache-Control "no-cache, no-store, must-revalidate";
            add_header Expires "0";
            add_header Pragma "no-cache";
        }
    }
}
