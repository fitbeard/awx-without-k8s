services:
  postgres:
    image: docker.io/postgres:{{ awx_pg_version }}
    container_name: postgres
    hostname: postgres
    restart: unless-stopped
    network_mode: host
    command: ["-p", "{{ awx_pg_port }}", "-c", "ssl=on", "-c", "ssl_cert_file=/etc/ssl/pg/server.crt", "-c", "ssl_key_file=/etc/ssl/pg/server.key"]
    volumes:
      - "{{ awx_pg_directory }}/data:/var/lib/postgresql/data:Z"
      - "{{ awx_pg_directory }}/postgresql.crt:/etc/ssl/pg/server.crt:ro"
      - "{{ awx_pg_directory }}/postgresql.key:/etc/ssl/pg/server.key:ro"
    environment:
      POSTGRES_DB: {{ awx_pg_database }}
      POSTGRES_USER: {{ awx_pg_username }}
      POSTGRES_PASSWORD: {{ awx_pg_password }}
      POSTGRES_INITDB_ARGS: {{ awx_pg_initdb_args }}
      POSTGRES_HOST_AUTH_METHOD: {{ awx_pg_host_auth_method }}
      PGDATA: /var/lib/postgresql/data/pgdata
