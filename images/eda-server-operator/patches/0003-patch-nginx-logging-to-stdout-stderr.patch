From 88695a1953bb6d07cc741fad4cbae433aa05bc0c Mon Sep 17 00:00:00 2001
From: AAP Rebuild <aap-rebuild-bot@localhost>
Date: Mon, 4 May 2026 19:38:17 +0300
Subject: [PATCH] patch: nginx logging to stdout/stderr
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The three configmaps shipped by the operator had nginx writing to
file paths inside the container (/var/log/nginx/*.log) — invisible to
kubectl logs, lost on pod restart, and growing without rotation on the
overlay filesystem.

Switch all three to log over stdout/stderr instead, matching every
other container in the EDA stack:

- eda.configmap.yaml.j2 (eda-ui pod nginx_default_conf_template):
  access_log off  ->  /dev/stdout combined
  # error_log off ->  error_log /dev/stderr error

- eda-api.configmap.yaml.j2 (eda-api pod nginx sidecar):
  Drop 4 per-location file paths (static_*.log, proxy_*.log).
  Add http-level access_log /dev/stdout combined +
  error_log /dev/stderr error.

- eda-event-stream.configmap.yaml.j2:
  Add http-level access_log + error_log redirected to stdout/stderr.
---
 roles/eda/templates/eda-api.configmap.yaml.j2         | 11 ++++++-----
 .../eda/templates/eda-event-stream.configmap.yaml.j2  |  4 ++++
 roles/eda/templates/eda.configmap.yaml.j2             |  4 ++--
 3 files changed, 12 insertions(+), 7 deletions(-)

diff --git a/roles/eda/templates/eda-api.configmap.yaml.j2 b/roles/eda/templates/eda-api.configmap.yaml.j2
index 1393169..64f9e87 100644
--- a/roles/eda/templates/eda-api.configmap.yaml.j2
+++ b/roles/eda/templates/eda-api.configmap.yaml.j2
@@ -19,6 +19,11 @@ data:
             application/manifest+json webmanifest;
         }
 
+        # Single global access/error log to stdout/stderr so kubectl logs
+        # surfaces nginx activity. Per-location file paths replaced.
+        access_log /dev/stdout combined;
+        error_log /dev/stderr error;
+
         # Define the upstream gunicorn server
         upstream gunicorn {
             server 127.0.0.1:{{ api_django_port }};
@@ -31,8 +36,6 @@ data:
             {% endif %}
             location ^~ /api/eda/static/ {
                 alias {{ static_path }}/;
-                access_log /var/log/nginx/static_access.log;
-                error_log /var/log/nginx/static_error.log;
             }
             location ~ ^/api/eda {
                 proxy_pass http://gunicorn;  # Forward requests to Django app
@@ -44,13 +47,11 @@ data:
                 # Return 503 Service Unavailable with JSON response if gunicorn fails to respond
                 proxy_read_timeout {{ eda_nginx_read_timeout }}s;
                 error_page 504 =503 /json_503;
-                error_page 502 =503 /json_503;  # Optional, in case gunicorn is completely down    
+                error_page 502 =503 /json_503;  # Optional, in case gunicorn is completely down
             }
             location / {
                 root {{ static_path }};
                 try_files /index.html =404;
-                access_log /var/log/nginx/proxy_access.log;
-                error_log /var/log/nginx/proxy_error.log;
             }
             location = /json_503 {
                 # Custom JSON response for 503 Service Unavailable
diff --git a/roles/eda/templates/eda-event-stream.configmap.yaml.j2 b/roles/eda/templates/eda-event-stream.configmap.yaml.j2
index f002c25..f987f61 100644
--- a/roles/eda/templates/eda-event-stream.configmap.yaml.j2
+++ b/roles/eda/templates/eda-event-stream.configmap.yaml.j2
@@ -19,6 +19,10 @@ data:
             application/manifest+json webmanifest;
         }
 
+        # Log to stdout/stderr so kubectl logs surfaces nginx activity.
+        access_log /dev/stdout combined;
+        error_log /dev/stderr error;
+
         upstream eda-api-event-stream-backend {
             server 127.0.0.1:{{ event_stream_django_port }};
         }
diff --git a/roles/eda/templates/eda.configmap.yaml.j2 b/roles/eda/templates/eda.configmap.yaml.j2
index 0b5ef7e..13ac015 100644
--- a/roles/eda/templates/eda.configmap.yaml.j2
+++ b/roles/eda/templates/eda.configmap.yaml.j2
@@ -75,8 +75,8 @@ data:
             add_header X-Frame-Options "DENY" always;
             add_header X-Content-Type-Options "nosniff" always;
 
-            access_log off;
-            # error_log off;
+            access_log /dev/stdout combined;
+            error_log /dev/stderr error;
 
             autoindex off;
 
