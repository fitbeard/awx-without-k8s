From cb33f84b359a34669683b8f4a97dcd5b0b9ccf53 Mon Sep 17 00:00:00 2001
From: aap-rebuild <aap-rebuild-bot@localhost>
Date: Fri, 8 May 2026 19:39:40 +0300
Subject: [PATCH] patch: postgres-configuration secret host -> FQDN for
 cross-namespace ops

The new 'initialize_databases.yml' task introduced in bundle 2.6-709
connects from the gateway-operator pod to the postgres Service using the
'host' value baked into the gateway-postgres-configuration Secret. The
upstream template ships a BARE service name (e.g. 'aap-postgres-15')
which resolves only within the AAP CR's own namespace. When the operator
runs in a different namespace from the CR (our setup: operator in
'ansible-controllers', CR in 'ansible'), k8s DNS rejects bare names with
'could not translate host name' and the Create-PostgreSQL-users task
fails fatally.

Fix: append '.{{ ansible_operator_meta.namespace }}.svc.cluster.local'
to the host value. FQDN form resolves from any namespace; existing
in-namespace consumers (gateway pod, controller pod, etc.) work
unchanged because cluster DNS resolves both bare and FQDN forms when
the target is in the same namespace.

Same FQDN-suffix pattern as patches 0003 (controller_api_url 3-tier),
0004 (gateway_hostname), and 0006 (EDA automation_server_url FQDN).
Worth a public PR to upstream gateway-operator.
---
 roles/postgres/templates/postgres.gateway.secret.yaml.j2 | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/roles/postgres/templates/postgres.gateway.secret.yaml.j2 b/roles/postgres/templates/postgres.gateway.secret.yaml.j2
index c2b4764..033cb1e 100644
--- a/roles/postgres/templates/postgres.gateway.secret.yaml.j2
+++ b/roles/postgres/templates/postgres.gateway.secret.yaml.j2
@@ -10,6 +10,6 @@ stringData:
   username: '{{ gateway_database_username }}'
   database: '{{ gateway_database_name }}'
   port: '5432'
-  host: {{ _cr_name }}-postgres-{{ supported_pg_version }}
+  host: {{ _cr_name }}-postgres-{{ supported_pg_version }}.{{ ansible_operator_meta.namespace }}.svc.cluster.local
   postgres_admin_password: '{{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}'
   type: 'managed'
