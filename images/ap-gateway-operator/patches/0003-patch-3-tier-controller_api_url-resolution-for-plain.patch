From 7c9cedf21b0bb65e7b95139c09df629e5dde216d Mon Sep 17 00:00:00 2001
From: AAP Rebuild <aap-rebuild-bot@localhost>
Date: Wed, 6 May 2026 12:55:00 +0300
Subject: [PATCH] patch: 3-tier controller_api_url resolution for plain-k8s +
 gateway model

Three-level precedence chain in roles/.../combine_defaults.yml so SSO
config works across deployment shapes:

1. Explicit user override (TOP precedence). New task at the head of
   the chain honors spec.controller.api_url from the AAP CR if set.
   Use case: migration scenarios where controller is exposed
   externally (e.g. via its own Ingress) and clients bypass the
   gateway. The override skips both the polling and the FQDN fallback.

2. AWX status.URL polling. Existing block, kept. Now ALSO gated on
   'controller_api_url is not defined' so an explicit override wins.
   The default('route') filter changed to default(ingress_type |
   default('route')) so the AWX CR's missing spec.ingress_type
   inherits from the AAP CR. AAP ingress_type=none -> condition
   evaluates to 'none' != 'route' -> block skipped (avoids endless
   polling for status.URL that awx-operator never publishes on plain
   k8s without a Route).

3. In-cluster Service FQDN fallback. New task. When neither override
   nor polling produced a value (i.e. ingress_type=none, no Route, no
   explicit URL), synthesize from awx-operator's service naming:
       http://<awxname>-service.<namespace>.svc.cluster.local
   This is the architecturally correct value in the GATEWAY-FRONTED
   model where browsers only ever see the gateway URL and gateway's
   envoy proxies path-prefixed requests to in-cluster services.
   Server-side calls (gateway -> controller registration, sync, etc.)
   resolve via cluster DNS regardless of which namespace the operator
   pod, gateway pod, or AWX pod live in.

Symptom without these fixes: reconcile fails permanently with
   The conditional check '_controller.resources[0].status.URL is defined' failed.
on plain-k8s no-Route deployments.
---
 .../tasks/combine_defaults.yml                | 31 ++++++++++++++++++-
 1 file changed, 30 insertions(+), 1 deletion(-)

diff --git a/roles/ansibleautomationplatform/tasks/combine_defaults.yml b/roles/ansibleautomationplatform/tasks/combine_defaults.yml
index ee1d2be..545006f 100644
--- a/roles/ansibleautomationplatform/tasks/combine_defaults.yml
+++ b/roles/ansibleautomationplatform/tasks/combine_defaults.yml
@@ -15,6 +15,19 @@
     operand_timeout_annotation:
       aap.ansible.io/client-request-timeout: "{{ client_request_timeout | int }}s"
 
+# Explicit user override (highest precedence): when the AAP CR sets
+# spec.controller.api_url, use it as-is. Skips both the URL polling
+# block and the FQDN fallback. Use this for migration scenarios where
+# controller is exposed externally (e.g. via its own Ingress) and
+# clients bypass the gateway.
+- name: Use explicit controller URL from CR if set
+  ansible.builtin.set_fact:
+    controller_api_url: "{{ controller.api_url }}"
+  when:
+    - _controller_enabled | bool
+    - controller is defined
+    - controller.api_url is defined
+
 - name: Get existing AWX CR
   kubernetes.core.k8s_info:
     kind: AWX
@@ -48,7 +61,23 @@
   when:
     - _controller_enabled | bool
     - not _deploy_controller | bool
-    - _controller_ingress_check.resources[0].spec.ingress_type | default('route')| lower == 'route'
+    - controller_api_url is not defined
+    - _controller_ingress_check.resources[0].spec.ingress_type | default(ingress_type | default('route')) | lower == 'route'
+
+# Plain-k8s fallback: when ingress_type is not Route/Ingress (e.g. 'none'),
+# the URL polling block above is skipped because awx-operator never
+# populates AWX.status.URL. Synthesize controller_api_url from the
+# in-cluster Service FQDN so SSO env vars (CONTROLLER_SSO_URL etc.) are
+# still set in post_install.yml. awx-operator names the service
+# `<awxname>-service`. FQDN form so it works regardless of which
+# namespace the consumer (gateway, AWX, EDA) lives in.
+- name: Synthesize controller_api_url from Service FQDN when no external ingress
+  ansible.builtin.set_fact:
+    controller_api_url: "http://{{ _controller_name }}-service.{{ ansible_operator_meta.namespace }}.svc.cluster.local"
+  when:
+    - _controller_enabled | bool
+    - controller_api_url is not defined
+    - (ingress_type | default('route') | lower) not in ['route', 'ingress']
 
 - name: Get existing AutomationHub CR
   kubernetes.core.k8s_info:
