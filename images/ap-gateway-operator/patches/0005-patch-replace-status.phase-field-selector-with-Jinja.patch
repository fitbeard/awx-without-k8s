From 887fc3d4810af9459e75ea58763f6626d9f564e3 Mon Sep 17 00:00:00 2001
From: AAP Rebuild <aap-rebuild-bot@localhost>
Date: Wed, 6 May 2026 14:16:56 +0300
Subject: [PATCH] patch: replace status.phase field-selector with Jinja filter
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

post_install.yml:160 'Get the details for <controller>-web' uses a
field_selector 'status.phase=Running' on a kubernetes.core.k8s_info
PodList query.

operator-sdk's controller-runtime caching proxy only indexes
metadata.name and metadata.namespace by default; status.phase isn't
indexed, so the cache rejects the query with:
   'Index with name field:status.phase does not exist'

Custom field-selector indexes require Go-side SetField() calls in the
manager binary — not available in operator-sdk-driven ansible
operators. Workaround: drop field_selectors, do the Running filter in
the until clause via Jinja's selectattr.

Same effective behavior — wait until at least one Running web pod
exists — but uses an in-memory filter that doesn't depend on cache
indexing.
---
 roles/ansibleautomationplatform/tasks/post_install.yml | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/roles/ansibleautomationplatform/tasks/post_install.yml b/roles/ansibleautomationplatform/tasks/post_install.yml
index 878b9d2..e5a53b1 100644
--- a/roles/ansibleautomationplatform/tasks/post_install.yml
+++ b/roles/ansibleautomationplatform/tasks/post_install.yml
@@ -165,10 +165,11 @@
         label_selectors:
           - "app.kubernetes.io/name={{ _controller_name }}-web"
           - "app.kubernetes.io/component=awx"
-        field_selectors:
-          - status.phase=Running
       register: controller_web_pod
-      until: controller_web_pod.resources | length > 0
+      until: >
+        controller_web_pod.resources
+        | selectattr('status.phase', 'eq', 'Running')
+        | list | length > 0
       retries: 10
       delay: 5
 
