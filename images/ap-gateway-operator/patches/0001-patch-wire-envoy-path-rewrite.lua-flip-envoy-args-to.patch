From f28640033e9e222eda6522ffaa290a9329cc6fd5 Mon Sep 17 00:00:00 2001
From: AAP Rebuild <aap-rebuild-bot@localhost>
Date: Wed, 6 May 2026 11:33:11 +0300
Subject: [PATCH] patch: wire envoy-path-rewrite.lua + flip envoy args to
 PATH-relative
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Three coupled changes so the gateway deployment works against stock
docker.io/envoyproxy/envoy (which has /usr/local/bin/envoy, not
/usr/bin/envoy, and does NOT ship the lua file):

1. roles/ansibleautomationplatform/files/envoy-path-rewrite.lua —
   the lua extracted from the gateway runtime image (built from
   automation-gateway-2.6.20260325 SRPM). Ships the path-rewrite logic
   the operator needs to mount alongside envoy.yaml.

2. roles/ansibleautomationplatform/templates/envoy.configmap.yaml.j2 —
   add a second data key 'envoy-path-rewrite.lua' populated via
   lookup('file', 'envoy-path-rewrite.lua') so the configmap can be
   subPath-mounted into the proxy container.

3. roles/ansibleautomationplatform/templates/gateway.deployment.yaml.j2 —
   flip proxy container args from '/usr/bin/envoy' to 'envoy' (PATH-
   relative, works on both stock envoyproxy/envoy and the maistra-proxy
   image), and add a second subPath mount for the lua file at
   /etc/ansible-automation-platform/gateway/envoy-path-rewrite.lua so
   envoy.yaml's filter-config reference resolves.
---
 .../files/envoy-path-rewrite.lua              | 83 +++++++++++++++++++
 .../templates/envoy.configmap.yaml.j2         |  2 +
 .../templates/gateway.deployment.yaml.j2      |  5 +-
 3 files changed, 89 insertions(+), 1 deletion(-)
 create mode 100644 roles/ansibleautomationplatform/files/envoy-path-rewrite.lua

diff --git a/roles/ansibleautomationplatform/files/envoy-path-rewrite.lua b/roles/ansibleautomationplatform/files/envoy-path-rewrite.lua
new file mode 100644
index 0000000..b5ddd15
--- /dev/null
+++ b/roles/ansibleautomationplatform/files/envoy-path-rewrite.lua
@@ -0,0 +1,83 @@
+function envoy_on_response(handle)
+    -- This script rewrites urls in the response by replacing the service base path
+    -- in Location headers and in the request body.
+    -- ex: translates /service-path/galaxy/ to /gateway-path/hub/ in service response bodies
+    handle:logDebug("Running lua script to rewrite response body.")
+    -- Ignore this script if the response is an upgrade response to prevent websockets from breaking
+    local status_code = handle:headers():get(":status")
+    if status_code == "101" then
+        return
+    end
+
+    -- Ignore this script if the response is from a StreamingHTTPResponse event-stream
+    local ctype = handle:headers():get("content-type")
+    if ctype and string.match(ctype, "text/event%-stream") then
+        handle:headers():replace("X-Accel-Buffering", "no")
+        return
+    end
+
+    local location = handle:headers():get("Location")
+
+    -- If the location contains __gateway_no_rewrite__=1 (e.g. as a GET param),
+    -- then do not rewrite the location header.
+    if location and string.match(location, "__gateway_no_rewrite__=1") then
+        return
+    end
+
+    local prefix_rewrite = handle:metadata():get("prefix")
+    local prefix = handle:metadata():get("prefix_rewrite")
+
+    if location then
+        local new_location = string.gsub(location, prefix, prefix_rewrite)
+        handle:headers():replace("Location", new_location)
+    end
+    local body = handle:body()
+    if body then
+        body_bytes = body:getBytes(0, body:length())
+        local modified_body = string.gsub(body_bytes, prefix, prefix_rewrite)
+
+        local content_length = handle:body():setBytes(modified_body)
+        handle:headers():replace("content-length", content_length)
+    end
+end
+
+function envoy_on_request(handle)
+    -- Translate urls in the request body back to the service's base path.
+    -- ex: translates /gateway-path/hub/ to /service-path/galaxy/ in service request bodies
+    handle:logDebug("Running lua script to rewrite request body.")
+
+    -- Ignore this script if the request is an upgrade request to prevent websockets from breaking
+    local upgrade_header = handle:headers():get("upgrade")
+    if upgrade_header then
+        return
+    end
+
+    local prefix_rewrite = handle:metadata():get("prefix")
+    local prefix = handle:metadata():get("prefix_rewrite")
+
+    local path = handle:headers():get(":path")
+    if string.match(path, "=") then
+        -- need to escape "-"
+        local match = "%=" .. string.gsub(prefix_rewrite, "%-", "%%-")
+        local replace = "%=" .. string.gsub(prefix, "%-", "%%-")
+
+        handle:logDebug(match)
+        handle:logDebug(replace)
+
+        local new_path = string.gsub(path, match, replace)
+
+        -- if the query param is urlencoded, replace those instead
+        new_path = string.gsub(new_path, string.gsub(match, "/", "%%%%2F"), string.gsub(replace, "/", "%%%%2F"))
+
+        handle:headers():replace(":path", new_path)
+    end
+
+    local body = handle:body()
+    if body then
+        body_bytes = body:getBytes(0, body:length())
+        local modified_body = string.gsub(body_bytes, prefix_rewrite, prefix)
+
+        local content_length = handle:body():setBytes(modified_body)
+        handle:headers():replace("content-length", content_length)
+    end
+end
diff --git a/roles/ansibleautomationplatform/templates/envoy.configmap.yaml.j2 b/roles/ansibleautomationplatform/templates/envoy.configmap.yaml.j2
index f4c4344..f7d7662 100644
--- a/roles/ansibleautomationplatform/templates/envoy.configmap.yaml.j2
+++ b/roles/ansibleautomationplatform/templates/envoy.configmap.yaml.j2
@@ -78,3 +78,5 @@ data:
         socket_address:
           address: 0.0.0.0
           port_value: 19000
+  envoy-path-rewrite.lua: |
+    {{ lookup('file', 'envoy-path-rewrite.lua') | indent(4) }}
diff --git a/roles/ansibleautomationplatform/templates/gateway.deployment.yaml.j2 b/roles/ansibleautomationplatform/templates/gateway.deployment.yaml.j2
index b3ee7e4..0ffdd42 100644
--- a/roles/ansibleautomationplatform/templates/gateway.deployment.yaml.j2
+++ b/roles/ansibleautomationplatform/templates/gateway.deployment.yaml.j2
@@ -135,7 +135,7 @@ spec:
       - name: proxy
         image: '{{ _image_proxy }}'
         imagePullPolicy: '{{ image_pull_policy }}'
-        args: ['/usr/bin/envoy', '-c', '/etc/ansible-automation-platform/gateway/envoy.yaml']
+        args: ['envoy', '-c', '/etc/ansible-automation-platform/gateway/envoy.yaml']
         livenessProbe:
           httpGet:
             path: "/api/gateway/v1/ping/"
@@ -149,6 +149,9 @@ spec:
         - name: envoy-conf
           mountPath: /etc/ansible-automation-platform/gateway/envoy.yaml
           subPath: envoy.yaml
+        - name: envoy-conf
+          mountPath: /etc/ansible-automation-platform/gateway/envoy-path-rewrite.lua
+          subPath: envoy-path-rewrite.lua
 {% if combined_api.resource_requirements is defined %}
         resources: {{ combined_api.resource_requirements }}
 {% endif %}
