From 12d3edc38c219b5c073ffbe3eab3f240f961cd4a Mon Sep 17 00:00:00 2001
From: AAP Rebuild <aap-rebuild-bot@localhost>
Date: Wed, 6 May 2026 13:42:39 +0300
Subject: [PATCH] patch: gateway_hostname FQDN suffix on initialize_gateway
 service_node
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

initialize_gateway.yml:93 ('Update automation platform gateway
service_nodes' loop) used bare-hostname 'http://{{ name }}' for the
gateway_hostname module input. Bare hostname only resolves when the
operator pod is in the SAME namespace as the gateway service — fails
under cluster-wide watch with 'URLError [Errno -2] Name or service
not known'.

Minimal fix: only add the .{{ namespace }}.svc.cluster.local FQDN
suffix. Keep the original service-name choice ({{ name }}) — the
upstream role has both '{{ name }}' (bare, this line) and
'{{ name }}-api' (9 other lines) variants for gateway_hostname; we
don't know which Red Hat intended where. Preserve the original line's
choice and only fix what's actually broken (cross-namespace DNS).

Symptom without fix: PLAY RECAP shows failed=1 with
   URLError <urlopen error [Errno -2] Name or service not known>
---
 roles/ansibleautomationplatform/tasks/initialize_gateway.yml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/roles/ansibleautomationplatform/tasks/initialize_gateway.yml b/roles/ansibleautomationplatform/tasks/initialize_gateway.yml
index 419f559..6e6ecf4 100644
--- a/roles/ansibleautomationplatform/tasks/initialize_gateway.yml
+++ b/roles/ansibleautomationplatform/tasks/initialize_gateway.yml
@@ -90,7 +90,7 @@
   ansible.platform.service_node:
     name: '{{ item }}'
     state: absent
-    gateway_hostname: "http://{{ ansible_operator_meta.name }}"
+    gateway_hostname: "http://{{ ansible_operator_meta.name }}.{{ ansible_operator_meta.namespace }}.svc.cluster.local"
     gateway_validate_certs: False
     gateway_token: "{{ gateway_oauth2_token_value }}"
   loop: '{{ _service_nodes.stdout }}'
